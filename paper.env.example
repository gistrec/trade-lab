# trade-lab paper-trading environment variables.
#
# Copy these into your existing `.env` (which must stay in .gitignore).
# Never commit a populated version.
#
# The execution layer is exchange-agnostic via CCXT. The TRADE_LAB_PAPER_*
# variables below switch exchange + sandbox flag in one place. Switching
# from Binance testnet to Kraken live is just changing
# TRADE_LAB_PAPER_EXCHANGE=kraken and TRADE_LAB_PAPER_SANDBOX=false.

# ----------------------------------------------------------------------
# Required (paper-trading layer refuses to start without all of these)
# ----------------------------------------------------------------------

# CCXT exchange id. Tested on `binance` (testnet) and `kraken` (mainnet).
# Any CCXT-supported exchange with REST trading endpoints will work in
# principle; behaviour for partial fills and order-types may vary.
TRADE_LAB_PAPER_EXCHANGE=binance

# Sandbox / testnet flag. MUST be set explicitly.
# - true  → CCXT set_sandbox_mode(True). Use this for Binance testnet.
# - false → mainnet. Requires TRADE_LAB_PAPER_ALLOW_MAINNET=true too.
TRADE_LAB_PAPER_SANDBOX=true

# API key + secret. Obtained from the exchange UI.
# For Binance testnet: https://testnet.binance.vision/key/generate
# NEVER commit these. `.env` is already in .gitignore.
TRADE_LAB_PAPER_API_KEY=
TRADE_LAB_PAPER_API_SECRET=

# ----------------------------------------------------------------------
# Optional (defaults shown)
# ----------------------------------------------------------------------

# Refuse-by-default to mainnet. Even if TRADE_LAB_PAPER_SANDBOX=false,
# the broker will not connect unless this is also true. Forces an
# explicit conscious decision to leave the testnet.
# TRADE_LAB_PAPER_ALLOW_MAINNET=false

# Quote currency. The strategy targets are denominated in this.
# TRADE_LAB_PAPER_QUOTE=USDT

# Assets composing the market-basket index. Comma-separated.
# The deployable strategy is market-basket TSMOM on equal-weight of these.
# TRADE_LAB_PAPER_BASKET=BTC,ETH,BNB,SOL,ADA,XRP,DOGE

# CCXT request timeout in milliseconds.
# TRADE_LAB_PAPER_TIMEOUT_MS=20000
