# trade-lab paper-trading environment variables.
#
# TWO symmetric environment files, one per venue:
#   .env.testnet  — testnet (Binance Spot Testnet). The default: every
#                   paper command without --env-file reads this file.
#   .env.mainnet  — mainnet (real money). Selected explicitly per run:
#                     trade-lab paper-dry-run --env-file .env.mainnet ...
# A missing file is a hard error — paper commands never fall back to a
# legacy `.env` (non-paper commands still read `.env` for their own
# vars). The selected file overrides ambient shell variables.
# Both must stay in .gitignore. Never commit a populated version.
#
# Each environment also keeps its OWN journal and state files
# (enforced at runtime — mixing raises):
#   testnet: data/journal/cycles.jsonl          data/state/orders.json
#   mainnet: data/journal/cycles_mainnet.jsonl  data/state/orders_mainnet.json

# ----------------------------------------------------------------------
# Required (paper-trading layer refuses to start without all of these)
# ----------------------------------------------------------------------

# CCXT exchange id. `binance` for both testnet and mainnet.
TRADE_LAB_PAPER_EXCHANGE=binance

# Sandbox / testnet flag. MUST be set explicitly.
# - true  → CCXT set_sandbox_mode(True). Binance testnet (.env.testnet).
# - false → mainnet (.env.mainnet). Requires ALLOW_MAINNET=true too.
TRADE_LAB_PAPER_SANDBOX=true

# API key + secret. Obtained from the exchange UI.
# - Testnet: https://testnet.binance.vision/key/generate
# - Mainnet: Binance → API Management. Permissions: "Enable Reading"
#   (+ "Enable Spot & Margin Trading" ONLY when live orders are enabled).
#   NEVER enable withdrawals/transfers/futures. Restrict to the server IP.
# NEVER commit these. `.env` / `.env.*` / `paper.env*` are already in
# .gitignore (`.env.example` and this template stay tracked).
TRADE_LAB_PAPER_API_KEY=
TRADE_LAB_PAPER_API_SECRET=

# ----------------------------------------------------------------------
# Mainnet gate — three independent flags before real money moves
# ----------------------------------------------------------------------

# Flag 2 of 3. Even with SANDBOX=false, nothing connects unless this is
# also true. Forces an explicit conscious decision to leave the testnet.
# TRADE_LAB_PAPER_ALLOW_MAINNET=false

# Flag 3 of 3. SANDBOX=false + ALLOW_MAINNET=true only unlock READ paths
# (paper-status, paper-dry-run). Placing real orders (paper-place-orders,
# paper-place-test-order) additionally requires this. Enable it only
# after the mainnet dry-run observation period (see execution/README.md).
# Setting it in a testnet env file is an error.
# TRADE_LAB_PAPER_MAINNET_LIVE_ORDERS=false

# ----------------------------------------------------------------------
# Optional (defaults shown)
# ----------------------------------------------------------------------

# Quote currency. The strategy targets are denominated in this.
# TRADE_LAB_PAPER_QUOTE=USDT

# Assets composing the market-basket index. Comma-separated.
# The deployable strategy is market-basket TSMOM on equal-weight of these.
# TRADE_LAB_PAPER_BASKET=BTC,ETH,BNB,SOL,ADA,XRP,DOGE

# CCXT request timeout in milliseconds.
# TRADE_LAB_PAPER_TIMEOUT_MS=20000

# ----------------------------------------------------------------------
# MySQL mirror (data locality — optional but recommended in production)
# ----------------------------------------------------------------------

# Off-host mirror of data/journal + data/state, reconciled automatically
# after every cycle and on `trade-lab db-mirror`. A fresh host gets its
# files back with `trade-lab db-restore`. Unset = mirror disabled (dev).
# URL-encode special characters in the password. Put the SAME url in
# .env.testnet and .env.mainnet — rows are keyed by file path, so the
# environments stay separated inside the shared database.
# TRADE_LAB_DB_URL=mysql://trade-lab:password@host:3306/trade-lab

# CA bundle path, only for clusters that require verified TLS.
# TRADE_LAB_DB_SSL_CA=
